# ============================================================
# Menttio — Variables de entorno requeridas
# Copia este archivo como .env.local y rellena los valores
# ============================================================

# ------------------------------------------------------------
# Stripe — Claves de API
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...          # Clave secreta de Stripe (Live)
STRIPE_WEBHOOK_SECRET=whsec_...        # Secret del webhook de Stripe

# ------------------------------------------------------------
# Stripe — Price IDs de suscripción (Live)
# Obtén los IDs en dashboard.stripe.com > Productos > Precios
# ------------------------------------------------------------
STRIPE_PRICE_BASIC=price_...           # Plan Básico (Live)
STRIPE_PRICE_BASIC_BETA=price_...      # Plan Básico Beta (Live)
STRIPE_PRICE_PREMIUM=price_...         # Plan Premium (Live)

# ------------------------------------------------------------
# Stripe — Price IDs de planes exentos (0€)
# Usados por handleSubscriptionExempt para profesores exentos
# ------------------------------------------------------------
STRIPE_PRICE_EXEMPT_BASIC=price_...    # Plan Básico exento (0€)
STRIPE_PRICE_EXEMPT_PREMIUM=price_...  # Plan Premium exento (0€)

# ------------------------------------------------------------
# n8n — Webhooks de automatización
# ------------------------------------------------------------
N8N_CREATE_USER_WEBHOOK_URL=https://...    # Webhook para crear usuario corporativo
N8N_NUEVO_PROFESOR_WEBHOOK_URL=https://... # Webhook para notificar nuevo profesor

# ------------------------------------------------------------
# Base44
# ------------------------------------------------------------
BASE44_APP_ID=...   # ID de la aplicación en Base44
